POSTGRES_USER=dockpulse
POSTGRES_PASSWORD=generate-strong-password
POSTGRES_DB=dockpulse
# Signs JWTs. Generate with: openssl rand -hex 32 — must be 32+ random bytes.
# Rotating this invalidates every issued token.
SECRET_KEY=
MQTT_PORT=8883
TAG=sha-abcdef0

# Public MQTT broker (mqtt.dockpulse.xyz). Cert is provisioned by the
# mqtt-cert-renew sidecar via Let's Encrypt DNS-01 against the Cloudflare zone.
MQTT_PUBLIC_HOSTNAME=mqtt.dockpulse.xyz
LEGO_EMAIL=ops@dockpulse.xyz
CLOUDFLARE_DNS_API_TOKEN=cloudflare-token-with-zone-dns-edit
