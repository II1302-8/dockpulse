{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "bunx concurrently -k \"API_URL=http://localhost:4010 MOCK_SSE_URL=http://localhost:4011 vite\" \"bunx @stoplight/prism-cli mock ../docs/api/openapi.yml\" \"bun run mock/sse-server.ts\"",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "biome check ./src tailwind.config.js vite.config.ts",
    "lint:fix": "biome check --write ./src tailwind.config.js vite.config.ts",
    "format": "biome format --write ./src tailwind.config.js vite.config.ts",
    "gen:api": "openapi-typescript ../docs/api/openapi.yml -o src/api-types.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "panzoom": "^9.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^24.12.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.12",
    "tailwindcss": "3",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  }
}
